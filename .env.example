# Where quote-form submissions are delivered, via formsubmit.co.
#
# Option A (setup): the raw inbox address. Fine to start with, and required
# once so FormSubmit can send its activation email:
#   FORMSUBMIT_TARGET=info@beyondhome.com.ng
#
# Option B (preferred after activation): the random alias string FormSubmit
# shows once the address is activated. It delivers to the same inbox but
# keeps the real address out of configuration:
#   FORMSUBMIT_TARGET=a1b2c3d4e5f6a7b8
#
# This variable is server-only (no NEXT_PUBLIC_ prefix); the address is
# never exposed to the browser.
FORMSUBMIT_TARGET=

# Absolute production URL. Canonicals, Open Graph URLs, JSON-LD, sitemap
# and robots.txt all derive from it. Falls back to
# https://beyondhome.com.ng when unset.
NEXT_PUBLIC_SITE_URL=
